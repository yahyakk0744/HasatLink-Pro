{
  "installCommand": "npm install --legacy-peer-deps",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://hasatlink-api.onrender.com/api/:path*" },
    { "source": "/uploads/:path*", "destination": "https://hasatlink-api.onrender.com/uploads/:path*" },
    { "source": "/socket.io/:path*", "destination": "https://hasatlink-api.onrender.com/socket.io/:path*" },
    { "source": "/__/auth/(.*)", "destination": "https://hasatlink-33.firebaseapp.com/__/auth/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
