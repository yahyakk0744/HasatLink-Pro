# === HasatLink Content Pipeline ===
# Kopyala: cp .env.example .env ve doldur

# Aşama 1: Metin/Senaryo
GEMINI_API_KEY=your_gemini_key_here
GROQ_API_KEY=your_groq_key_here

# Aşama 2: Görsel
HUGGINGFACE_API_KEY=your_hf_key_here
# Pollinations.ai = API key gerektirmez

# Aşama 3: TTS
GOOGLE_CLOUD_TTS_KEY=your_gcloud_tts_key_here
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Aşama 5: Sosyal Medya (n8n üzerinden, opsiyonel direkt kullanım)
# FACEBOOK_PAGE_TOKEN=
# INSTAGRAM_ACCESS_TOKEN=
# TIKTOK_SESSION_ID=
